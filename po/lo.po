#: data/metainfo/org.gnome.Software.metainfo.xml.in:7 src/gs-shell.ui:35
#: src/org.gnome.Software.desktop.in:2
msgid "Software"
msgstr "ຊອບແວ"

#: data/metainfo/org.gnome.Software.metainfo.xml.in:8
msgid "Install and update apps"
msgstr "ຕິດຕັ້ງ ແລະ ອັບເດດແອັບ"

#: data/metainfo/org.gnome.Software.metainfo.xml.in:10
msgid ""
"Software allows you to find and install new apps and system extensions and "
"remove existing installed apps."
msgstr "ຊອບແວ ຊ່ວຍໃຫ້ທ່ານສາມາດຊອກຫາ ແລະ ຕິດຕັ້ງແອັບໃໝ່ ແລະ ສ່ວນຂະຫຍາຍລະບົບ ແລະ ລຶບແອັບທີ່ມີຢູ່ແລ້ວອອກ."

#: data/metainfo/org.gnome.Software.metainfo.xml.in:14
msgid ""
"Software showcases featured and popular apps with useful descriptions and "
"multiple screenshots per app. Apps can be found either through browsing the "
"list of categories or by searching. It also allows you to update your system "
"using an offline update."
msgstr "ຊອບແວ ສະແດງແອັບທີ່ແນະນຳ ແລະ ເປັນທີ່ນິຍົມ ພ້ອມຄຳອະທິບາຍທີ່ເປັນປະໂຫຍດ ແລະ ຮູບພາບໜ້າຈໍຫຼາຍຮູບຕໍ່ແອັບ. ແອັບສາມາດຊອກຫາໄດ້ໂດຍການເບິ່ງລາຍການໝວດໝູ່ ຫຼື ໂດຍການຄົ້ນຫາ. ມັນຍັງຊ່ວຍໃຫ້ທ່ານສາມາດອັບເດດລະບົບຂອງທ່ານໂດຍການໃຊ້ອັບເດດແບບອອບໄລນ໌."

#: data/metainfo/org.gnome.Software.metainfo.xml.in:25
msgid "Overview panel"
msgstr "ແຜງພາບລວມ"

#: data/metainfo/org.gnome.Software.metainfo.xml.in:29
#: data/metainfo/org.gnome.Software.metainfo.xml.in:33
msgid "Details panel"
msgstr "ແຜງລາຍລະອຽດ"

#: data/metainfo/org.gnome.Software.metainfo.xml.in:37
msgid "Installed panel"
msgstr "ແຜງທີ່ຕິດຕັ້ງແລ້ວ"

#: data/metainfo/org.gnome.Software.metainfo.xml.in:41
#: data/metainfo/org.gnome.Software.metainfo.xml.in:45
msgid "Updates panel"
msgstr "ແຜງອັບເດດ"

#: data/metainfo/org.gnome.Software.metainfo.xml.in:49
msgid "The update details"
msgstr "ລາຍລະອຽດການອັບເດດ"

#. developer_name tag deprecated with Appstream 1.0
#: data/metainfo/org.gnome.Software.metainfo.xml.in:2883
#: src/gs-application.c:269
msgid "The GNOME Project"
msgstr "ໂຄງການ GNOME"

#: data/org.gnome.software.dkms-helper.policy.in.in:11
msgid "Test akmods key in Shim UEFI"
msgstr "ທົດສອບຄີ akmods ໃນ Shim UEFI"

#: data/org.gnome.software.dkms-helper.policy.in.in:12
msgid "Authentication is required to test akmods key in Shim UEFI"
msgstr "ຕ້ອງການການຢືນຢັນຕົວຕົນເພື່ອທົດສອບຄີ akmods ໃນ Shim UEFI"

#: data/org.gnome.software.dkms-helper.policy.in.in:22
msgid "Enroll akmods key to Shim UEFI"
msgstr "ລົງທະບຽນຄີ akmods ໃສ່ Shim UEFI"

#: data/org.gnome.software.dkms-helper.policy.in.in:23
msgid "Authentication is required to enroll akmods key to Shim UEFI"
msgstr "ຕ້ອງການການຢືນຢັນຕົວຕົນເພື່ອລົງທະບຽນຄີ akmods ໃສ່ Shim UEFI"

#: data/org.gnome.software.dkms-helper.policy.in.in:33
msgid "Test DKMS key in Shim UEFI"
msgstr "ທົດສອບຄີ DKMS ໃນ Shim UEFI"

#: data/org.gnome.software.dkms-helper.policy.in.in:34
msgid "Authentication is required to test DKMS key in Shim UEFI"
msgstr "ຕ້ອງການການຢືນຢັນຕົວຕົນເພື່ອທົດສອບຄີ DKMS ໃນ Shim UEFI"

#: data/org.gnome.software.dkms-helper.policy.in.in:44
msgid "Enroll DKMS key to Shim UEFI"
msgstr "ລົງທະບຽນຄີ DKMS ໃສ່ Shim UEFI"

#: data/org.gnome.software.dkms-helper.policy.in.in:45
msgid "Authentication is required to enroll DKMS key to Shim UEFI"
msgstr "ຕ້ອງການການຢືນຢັນຕົວຕົນເພື່ອລົງທະບຽນຄີ DKMS ໃສ່ Shim UEFI"

#: data/org.gnome.software.external-appstream.policy.in.in:11
msgid "Install an appstream file into a system location"
msgstr "ຕິດຕັ້ງໄຟລ໌ appstream ໄປໃສ່ທີ່ຕັ້ງຂອງລະບົບ"

#: data/org.gnome.software.external-appstream.policy.in.in:12
msgid "Installing an appstream file into a system location"
msgstr "ກຳລັງຕິດຕັ້ງໄຟລ໌ appstream ໄປໃສ່ທີ່ຕັ້ງຂອງລະບົບ"

#: data/org.gnome.software.gschema.xml:5
msgid "A list of compatible projects"
msgstr "ລາຍການໂຄງການທີ່ເຂົ້າກັນໄດ້"

#: data/org.gnome.software.gschema.xml:6
msgid ""
"This is a list of compatible projects we should show such as GNOME, KDE and "
"XFCE."
msgstr "ນີ້ແມ່ນລາຍການໂຄງການທີ່ເຂົ້າກັນໄດ້ທີ່ພວກເຮົາຄວນສະແດງເຊັ່ນ GNOME, KDE ແລະ XFCE."

#: data/org.gnome.software.gschema.xml:10
msgid "Whether to manage updates and upgrades in GNOME Software"
msgstr "ຈະຈັດການການອັບເດດ ແລະ ອັບເກຣດໃນ ຊອບແວ GNOME ຫຼືບໍ່"

#: data/org.gnome.software.gschema.xml:11
msgid ""
"If disabled, GNOME Software will hide the updates panel, not perform any "
"automatic updates actions or prompt for upgrades."
msgstr "ຖ້າປິດໃຊ້ງານ, ຊອບແວ GNOME ຈະເຊື່ອງແຜງອັບເດດ, ບໍ່ດຳເນີນການອັບເດດອັດຕະໂນມັດ ຫຼື ແຈ້ງເຕືອນການອັບເກຣດ."

#: data/org.gnome.software.gschema.xml:15
msgid "Automatically download and install updates"
msgstr "ດາວໂຫຼດ ແລະ ຕິດຕັ້ງການອັບເດດອັດຕະໂນມັດ"

#: data/org.gnome.software.gschema.xml:16
msgid ""
"If enabled, GNOME Software automatically downloads software updates in the "
"background, also installing ones that do not require a reboot."
msgstr "ຖ້າເປີດໃຊ້ງານ, ຊອບແວ GNOME ຈະດາວໂຫຼດການອັບເດດຊອບແວໃນພື້ນຫຼັງໂດຍອັດຕະໂນມັດ, ແລະ ຍັງຕິດຕັ້ງອັນທີ່ບໍ່ຕ້ອງການການຣີບູດ."

#: data/org.gnome.software.gschema.xml:20
msgid "Notify the user about software updated in the background"
msgstr "ແຈ້ງເຕືອນຜູ້ໃຊ້ກ່ຽວກັບຊອບແວທີ່ອັບເດດໃນພື້ນຫຼັງ"

#: data/org.gnome.software.gschema.xml:21
msgid ""
"If enabled, GNOME Software notifies the user about updates that happened "
"whilst the user was idle."
msgstr "ຖ້າເປີດໃຊ້ງານ, ຊອບແວ GNOME ຈະແຈ້ງເຕືອນຜູ້ໃຊ້ກ່ຽວກັບການອັບເດດທີ່ເກີດຂຶ້ນໃນຂະນະທີ່ຜູ້ໃຊ້ບໍ່ໄດ້ໃຊ້ງານ."

#: data/org.gnome.software.gschema.xml:25
msgid "Whether to automatically refresh when on a metered connection"
msgstr "ຈະໂຫຼດຂໍ້ມູນຄືນໃໝ່ອັດຕະໂນມັດຫຼືບໍ່ ເມື່ອເຊື່ອມຕໍ່ແບບຄິດຄ່າບໍລິການ"

#: data/org.gnome.software.gschema.xml:26
msgid ""
"If enabled, GNOME Software automatically refreshes in the background even "
"when using a metered connection (eventually downloading some metadata, "
"checking for updates, etc., which may incur in costs for the user)."
msgstr "ຖ້າເປີດໃຊ້ງານ, ຊອບແວ GNOME ຈະໂຫຼດຂໍ້ມູນຄືນໃໝ່ໃນພື້ນຫຼັງໂດຍອັດຕະໂນມັດ ເຖິງແມ່ນວ່າຈະໃຊ້ການເຊື່ອມຕໍ່ແບບຄິດຄ່າບໍລິການ (ເຊິ່ງອາດຈະດາວໂຫຼດຂໍ້ມູນເມຕາ, ກວດສອບການອັບເດດ, ແລະ ອື່ນໆ, ເຊິ່ງອາດຈະມີຄ່າໃຊ້ຈ່າຍສຳລັບຜູ້ໃຊ້)."

#: data/org.gnome.software.gschema.xml:30
msgid "Whether it’s the very first run of GNOME Software"
msgstr "ນີ້ແມ່ນການເປີດໃຊ້ ຊອບແວ GNOME ຄັ້ງທຳອິດຫຼືບໍ່"

#: data/org.gnome.software.gschema.xml:34
msgid "Show star ratings next to applications"
msgstr "ສະແດງການໃຫ້ຄະແນນດາວຖັດຈາກແອັບພລິເຄຊັນ"

#: data/org.gnome.software.gschema.xml:38
msgid "Filter applications based on the default branch set for the remote"
msgstr "ກັ່ນຕອງແອັບພລິເຄຊັນໂດຍອີງໃສ່ສາຂາເລີ່ມຕົ້ນທີ່ຕັ້ງໄວ້ສຳລັບຣີໂໝດ"

#: data/org.gnome.software.gschema.xml:42
msgid "Non-free applications show a warning dialog before install"
msgstr "ແອັບພລິເຄຊັນທີ່ບໍ່ແມ່ນຊອບແວເສລີ ຈະສະແດງກ່ອງໂຕ້ຕອບຄຳເຕືອນກ່ອນການຕິດຕັ້ງ"

#: data/org.gnome.software.gschema.xml:43
msgid ""
"When non-free applications are installed a warning dialog can be shown. This "
"controls if that dialog is suppressed."
msgstr "ເມື່ອຕິດຕັ້ງແອັບພລິເຄຊັນທີ່ບໍ່ແມ່ນຊອບແວເສລີ, ກ່ອງໂຕ້ຕອບຄຳເຕືອນສາມາດສະແດງຂຶ້ນໄດ້. ການຕັ້ງຄ່ານີ້ຄວບຄຸມວ່າຈະປິດກັ້ນກ່ອງໂຕ້ຕອບນັ້ນຫຼືບໍ່."

#: data/org.gnome.software.gschema.xml:47
msgid "The last update check timestamp"
msgstr "ສະແຕມເວລາຂອງການກວດສອບອັບເດດຄັ້ງຫຼ້າສຸດ"

#: data/org.gnome.software.gschema.xml:51
msgid "The last upgrade notification timestamp"
msgstr "ສະແຕມເວລາຂອງການແຈ້ງເຕືອນອັບເກຣດຄັ້ງຫຼ້າສຸດ"

#: data/org.gnome.software.gschema.xml:55
msgid "The last update notification timestamp"
msgstr "ສະແຕມເວລາຂອງການແຈ້ງເຕືອນອັບເດດຄັ້ງຫຼ້າສຸດ"

#: data/org.gnome.software.gschema.xml:59
msgid "The timestamp of the first security update, cleared after update"
msgstr "ສະແຕມເວລາຂອງການອັບເດດຄວາມປອດໄພຄັ້ງທຳອິດ, ຈະຖືກລຶບອອກຫຼັງຈາກອັບເດດ"

#: data/org.gnome.software.gschema.xml:63
msgid "The last update timestamp"
msgstr "ສະແຕມເວລາຂອງການອັບເດດຄັ້ງຫຼ້າສຸດ"

#: data/org.gnome.software.gschema.xml:67
msgid "The age in seconds to verify the upstream screenshot is still valid"
msgstr "ອາຍຸ (ເປັນວິນາທີ) ເພື່ອກວດສອບວ່າຮູບພາບໜ້າຈໍຕົ້ນສະບັບຍັງໃຊ້ໄດ້ຢູ່"

#: data/org.gnome.software.gschema.xml:68
msgid ""
"Choosing a larger value will mean less round-trips to the remote server but "
"updates to the screenshots may take longer to show to the user. A value of 0 "
"means to never check the server if the image already exists in the cache."
msgstr "ການເລືອກຄ່າທີ່ສູງຂຶ້ນຈະໝາຍເຖິງການຕິດຕໍ່ກັບເຊີບເວີຣີໂໝດໜ້ອຍລົງ ແຕ່ການອັບເດດຮູບພາບໜ້າຈໍອາດຈະໃຊ້ເວລາດົນຂຶ້ນໃນການສະແດງໃຫ້ຜູ້ໃຊ້ເຫັນ. ຄ່າ 0 ໝາຍຄວາມວ່າຈະບໍ່ກວດສອບເຊີບເວີເລີຍ ຖ້າຮູບພາບມີຢູ່ໃນແຄສແລ້ວ."

#: data/org.gnome.software.gschema.xml:77
msgid "The server to use for application reviews"
msgstr "ເຊີບເວີທີ່ຈະໃຊ້ສຳລັບການຣີວິວແອັບພລິເຄຊັນ"

#: data/org.gnome.software.gschema.xml:81
msgid "The minimum karma score for reviews"
msgstr "ຄະແນນຄາມາຂັ້ນຕ່ຳສຳລັບການຣີວິວ"

#: data/org.gnome.software.gschema.xml:82
msgid "Reviews with karma less than this number will not be shown."
msgstr "ການຣີວິວທີ່ມີຄະແນນຄາມາໜ້ອຍກວ່າຕົວເລກນີ້ຈະບໍ່ຖືກສະແດງ."

#: data/org.gnome.software.gschema.xml:86
msgid "A list of official repositories that should not be considered 3rd party"
msgstr "ລາຍການຄັງເກັບທີ່ເປັນທາງການທີ່ບໍ່ຄວນຖືວ່າເປັນຂອງບຸກຄົນທີສາມ"

#: data/org.gnome.software.gschema.xml:90
msgid "A list of required repositories that cannot be disabled or removed"
msgstr "ລາຍການຄັງເກັບທີ່ຈຳເປັນທີ່ບໍ່ສາມາດປິດໃຊ້ງານ ຫຼື ລຶບອອກໄດ້"

#: data/org.gnome.software.gschema.xml:94
msgid "A list of official repositories that should be considered free software"
msgstr "ລາຍການຄັງເກັບທີ່ເປັນທາງການທີ່ຄວນຖືວ່າເປັນຊອບແວເສລີ"

#: data/org.gnome.software.gschema.xml:98
msgid ""
"The licence URL to use when an application should be considered free software"
