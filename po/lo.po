#: plugins/flatpak/gs-plugin-flatpak.c:2151
#, c-format
msgid ""
"Remote “%s” doesn't allow install of “%s”, possibly due to its filter. "
"Remove the filter and repeat the install. Detailed error: %s"
msgstr "Remote “%s” ບໍ່ອະນຸຍາດໃຫ້ຕິດຕັ້ງ “%s”, ອາດເປັນຍ້ອນຕົວກອງຂອງມັນ. ລົບຕົວກອງອອກແລ້ວຕິດຕັ້ງຄືນໃໝ່. ຂໍ້ຜິດພາດລະອຽດ: %s"

#. TRANSLATORS: as in laptop battery power
#: plugins/fwupd/gs-fwupd-app.c:70
msgid "System power is too low to perform the update"
msgstr "ພະລັງງານລະບົບຕ່ຳເກີນໄປທີ່ຈະອັບເດດ"

#. TRANSLATORS: as in laptop battery power
#: plugins/fwupd/gs-fwupd-app.c:74
#, c-format
msgid "System power is too low to perform the update (%u%%, requires %u%%)"
msgstr "ພະລັງງານລະບົບຕ່ຳເກີນໄປທີ່ຈະອັບເດດ (%u%%, ຕ້ອງການ %u%%)"

#. TRANSLATORS: for example, a Bluetooth mouse that is in powersave mode
#: plugins/fwupd/gs-fwupd-app.c:80
msgid "Device is unreachable, or out of wireless range"
msgstr "ບໍ່ສາມາດເຂົ້າເຖິງອຸປະກອນ, ຫຼື ຢູ່ນອກໄລຍະສັນຍານໄຮ້ສາຍ"

#. TRANSLATORS: for example the batteries *inside* the Bluetooth mouse
#: plugins/fwupd/gs-fwupd-app.c:86
#, c-format
msgid "Device battery power is too low"
msgstr "ພະລັງງານແບັດເຕີຣີຂອງອຸປະກອນຕ່ຳເກີນໄປ"

#. TRANSLATORS: for example the batteries *inside* the Bluetooth mouse
#: plugins/fwupd/gs-fwupd-app.c:89
#, c-format
msgid "Device battery power is too low (%u%%, requires %u%%)"
msgstr "ພະລັງງານແບັດເຕີຣີຂອງອຸປະກອນຕ່ຳເກີນໄປ (%u%%, ຕ້ອງການ %u%%)"

#. TRANSLATORS: usually this is when we're waiting for a reboot
#: plugins/fwupd/gs-fwupd-app.c:95
msgid "Device is waiting for the update to be applied"
msgstr "ອຸປະກອນກຳລັງລໍຖ້າການນຳໃຊ້ອັບເດດ"

#. TRANSLATORS: as in, wired mains power for a laptop
#: plugins/fwupd/gs-fwupd-app.c:99
msgid "Device requires AC power to be connected"
msgstr "ອຸປະກອນຕ້ອງການການເຊື່ອມຕໍ່ໄຟ AC"

#. TRANSLATORS: lid means "laptop top cover"
#: plugins/fwupd/gs-fwupd-app.c:103
msgid "Device cannot be used while the lid is closed"
msgstr "ບໍ່ສາມາດໃຊ້ອຸປະກອນໃນຂະນະທີ່ປິດຝາຢູ່"

#. TRANSLATORS: a specific part of hardware,
#. * the first %s is the device name, e.g. 'Unifying Receiver`
#: plugins/fwupd/gs-fwupd-app.c:212
#, c-format
msgid "%s Device Update"
msgstr "ອັບເດດອຸປະກອນ %s"

#. TRANSLATORS: the entire system, e.g. all internal devices,
#. * the first %s is the device name, e.g. 'ThinkPad P50`
#: plugins/fwupd/gs-fwupd-app.c:217
#, c-format
msgid "%s System Update"
msgstr "ອັບເດດລະບົບ %s"

#. TRANSLATORS: the EC is typically the keyboard controller chip,
#. * the first %s is the device name, e.g. 'ThinkPad P50`
#: plugins/fwupd/gs-fwupd-app.c:222
#, c-format
msgid "%s Embedded Controller Update"
msgstr "ອັບເດດ Embedded Controller ຂອງ %s"

#. TRANSLATORS: ME stands for Management Engine, the Intel AMT thing,
#. * the first %s is the device name, e.g. 'ThinkPad P50`
#: plugins/fwupd/gs-fwupd-app.c:227
#, c-format
msgid "%s ME Update"
msgstr "ອັບເດດ ME ຂອງ %s"

#. TRANSLATORS: ME stands for Management Engine (with Intel AMT),
#. * where the first %s is the device name, e.g. 'ThinkPad P50`
#: plugins/fwupd/gs-fwupd-app.c:232
#, c-format
msgid "%s Corporate ME Update"
msgstr "ອັບເດດ Corporate ME ຂອງ %s"

#. TRANSLATORS: ME stands for Management Engine, where
#. * the first %s is the device name, e.g. 'ThinkPad P50`
#: plugins/fwupd/gs-fwupd-app.c:237
#, c-format
msgid "%s Consumer ME Update"
msgstr "ອັບເດດ Consumer ME ຂອງ %s"

#. TRANSLATORS: the controller is a device that has other devices
#. * plugged into it, for example ThunderBolt, FireWire or USB,
#. * the first %s is the device name, e.g. 'Intel ThunderBolt`
#: plugins/fwupd/gs-fwupd-app.c:243
#, c-format
msgid "%s Controller Update"
msgstr "ອັບເດດ Controller ຂອງ %s"

#. TRANSLATORS: the Thunderbolt controller is a device that
#. * has other high speed Thunderbolt devices plugged into it;
#. * the first %s is the system name, e.g. 'ThinkPad P50`
#: plugins/fwupd/gs-fwupd-app.c:249
#, c-format
msgid "%s Thunderbolt Controller Update"
msgstr "ອັບເດດ Thunderbolt Controller ຂອງ %s"

#. TRANSLATORS: the CPU microcode is firmware loaded onto the CPU
#. * at system bootup
#: plugins/fwupd/gs-fwupd-app.c:254
#, c-format
msgid "%s CPU Microcode Update"
msgstr "ອັບເດດ CPU Microcode ຂອງ %s"

#. TRANSLATORS: configuration refers to hardware state,
#. * e.g. a security database or a default power value
#: plugins/fwupd/gs-fwupd-app.c:259
#, c-format
msgid "%s Configuration Update"
msgstr "ອັບເດດການຕັ້ງຄ່າຂອງ %s"

#. TRANSLATORS: battery refers to the system power source
#: plugins/fwupd/gs-fwupd-app.c:263
#, c-format
msgid "%s Battery Update"
msgstr "ອັບເດດແບັດເຕີຣີຂອງ %s"

#. TRANSLATORS: camera can refer to the laptop internal
#. * camera in the bezel or external USB webcam
#: plugins/fwupd/gs-fwupd-app.c:268
#, c-format
msgid "%s Camera Update"
msgstr "ອັບເດດກ້ອງຂອງ %s"

#. TRANSLATORS: TPM refers to a Trusted Platform Module
#: plugins/fwupd/gs-fwupd-app.c:272
#, c-format
msgid "%s TPM Update"
msgstr "ອັບເດດ TPM ຂອງ %s"

#. TRANSLATORS: TouchPad refers to a flat input device
#: plugins/fwupd/gs-fwupd-app.c:276
#, c-format
msgid "%s Touchpad Update"
msgstr "ອັບເດດ Touchpad ຂອງ %s"

#. TRANSLATORS: Mouse refers to a handheld input device
#: plugins/fwupd/gs-fwupd-app.c:280
#, c-format
msgid "%s Mouse Update"
msgstr "ອັບເດດເມົ້າສ໌ຂອງ %s"

#. TRANSLATORS: Keyboard refers to an input device for typing
#: plugins/fwupd/gs-fwupd-app.c:284
#, c-format
msgid "%s Keyboard Update"
msgstr "ອັບເດດແປ້ນພິມຂອງ %s"

#. TRANSLATORS: Storage Controller is typically a RAID or SAS adapter
#: plugins/fwupd/gs-fwupd-app.c:288
#, c-format
msgid "%s Storage Controller Update"
msgstr "ອັບເດດ Storage Controller ຂອງ %s"

#. TRANSLATORS: Network Interface refers to the physical
#. * PCI card, not the logical wired connection
#: plugins/fwupd/gs-fwupd-app.c:293
#, c-format
msgid "%s Network Interface Update"
msgstr "ອັບເດດ Network Interface ຂອງ %s"

#. TRANSLATORS: Video Display refers to the laptop internal display or
#. * external monitor
#: plugins/fwupd/gs-fwupd-app.c:298
#, c-format
msgid "%s Display Update"
msgstr "ອັບເດດຈໍສະແດງຜົນຂອງ %s"

#. TRANSLATORS: BMC refers to baseboard management controller which
#. * is the device that updates all the other firmware on the system
#: plugins/fwupd/gs-fwupd-app.c:303
#, c-format
msgid "%s BMC Update"
msgstr "ອັບເດດ BMC ຂອງ %s"

#. TRANSLATORS: Receiver refers to a radio device, e.g. a tiny Bluetooth
#. * device that stays in the USB port so the wireless peripheral works
#: plugins/fwupd/gs-fwupd-app.c:308
#, c-format
msgid "%s USB Receiver Update"
msgstr "ອັບເດດຕົວຮັບ USB ຂອງ %s"

#. TRANSLATORS: drive refers to a storage device, e.g. SATA disk
#: plugins/fwupd/gs-fwupd-app.c:312
#, c-format
msgid "%s Drive Update"
msgstr "ອັບເດດໄດຣຟ໌ຂອງ %s"

#. TRANSLATORS: flash refers to solid state storage, e.g. UFS or eMMC
#: plugins/fwupd/gs-fwupd-app.c:316
#, c-format
msgid "%s Flash Drive Update"
msgstr "ອັບເດດ Flash Drive ຂອງ %s"

#. TRANSLATORS: SSD refers to a Solid State Drive, e.g. non-rotating
#. * SATA or NVMe disk
#: plugins/fwupd/gs-fwupd-app.c:321
#, c-format
msgid "%s SSD Update"
msgstr "ອັບເດດ SSD ຂອງ %s"

#. TRANSLATORS: GPU refers to a Graphics Processing Unit, e.g.
#. * the "video card"
#: plugins/fwupd/gs-fwupd-app.c:326
#, c-format
msgid "%s GPU Update"
msgstr "ອັບເດດ GPU ຂອງ %s"

#. TRANSLATORS: Dock refers to the port replicator hardware laptops are
#. * cradled in, or lowered onto
#: plugins/fwupd/gs-fwupd-app.c:331
#, c-format
msgid "%s Dock Update"
msgstr "ອັບເດດ Dock ຂອງ %s"

#. TRANSLATORS: Dock refers to the port replicator device connected
#. * by plugging in a USB cable -- which may or may not also provide power
#: plugins/fwupd/gs-fwupd-app.c:336
#, c-format
msgid "%s USB Dock Update"
msgstr "ອັບເດດ USB Dock ຂອງ %s"

#: plugins/fwupd/gs-plugin-fwupd.c:903
msgid "Firmware"
msgstr "ເຟີມແວ"

#: plugins/fwupd/gs-plugin-fwupd.c:1946
msgid "Firmware update could not be applied: "
msgstr "ບໍ່ສາມາດນຳໃຊ້ອັບເດດເຟີມແວໄດ້: "

#: plugins/fwupd/org.gnome.Software.Plugin.Fwupd.metainfo.xml.in:6
msgid "Firmware Upgrade Support"
msgstr "ການຮອງຮັບການອັບເກຣດເຟີມແວ"

#: plugins/fwupd/org.gnome.Software.Plugin.Fwupd.metainfo.xml.in:7
msgid "Provides support for firmware upgrades"
msgstr "ສະໜອງການຮອງຮັບສຳລັບການອັບເກຣດເຟີມແວ"

#: plugins/packagekit/gs-packagekit-task.c:147
msgid "Install Unsigned Software?"
msgstr "ຕິດຕັ້ງຊັອບແວທີ່ບໍ່ມີລາຍເຊັນບໍ່?"

#: plugins/packagekit/gs-packagekit-task.c:148
msgid ""
"Software that is to be installed is not signed. It will not be possible to "
"verify the origin of updates to this software, or whether updates have been "
"tampered with."
msgstr "ຊັອບແວທີ່ຈະຕິດຕັ້ງບໍ່ມີລາຍເຊັນ. ຈະບໍ່ສາມາດຢັ້ງຢືນແຫຼ່ງທີ່ມາຂອງອັບເດດສຳລັບຊັອບແວນີ້ໄດ້, ຫຼື ວ່າອັບເດດໄດ້ຖືກປ່ຽນແປງຫຼືບໍ່."

#: plugins/packagekit/gs-packagekit-task.c:152
msgid "Download Unsigned Software?"
msgstr "ດາວໂຫຼດຊັອບແວທີ່ບໍ່ມີລາຍເຊັນບໍ່?"

#: plugins/packagekit/gs-packagekit-task.c:153
msgid ""
"Unsigned updates are available. Without a signature, it is not possible to "
"verify the origin of the update, or whether it has been tampered with."
msgstr "ມີອັບເດດທີ່ບໍ່ມີລາຍເຊັນ. ຖ້າບໍ່ມີລາຍເຊັນ, ຈະບໍ່ສາມາດຢັ້ງຢືນແຫຼ່ງທີ່ມາຂອງອັບເດດໄດ້, ຫຼື ວ່າມັນໄດ້ຖືກປ່ຽນແປງຫຼືບໍ່."

#: plugins/packagekit/gs-packagekit-task.c:157
msgid "Update Unsigned Software?"
msgstr "ອັບເດດຊັອບແວທີ່ບໍ່ມີລາຍເຊັນບໍ່?"

#: plugins/packagekit/gs-packagekit-task.c:158
msgid ""
"Unsigned updates are available. Without a signature, it is not possible to "
"verify the origin of the update, or whether it has been tampered with. "
"Software updates will be disabled until unsigned updates are either removed "
"or updated."
msgstr "ມີອັບເດດທີ່ບໍ່ມີລາຍເຊັນ. ຖ້າບໍ່ມີລາຍເຊັນ, ຈະບໍ່ສາມາດຢັ້ງຢືນແຫຼ່ງທີ່ມາຂອງອັບເດດໄດ້, ຫຼື ວ່າມັນໄດ້ຖືກປ່ຽນແປງຫຼືບໍ່. ການອັບເດດຊັອບແວຈະຖືກປິດໃຊ້ງານຈົນກວ່າອັບເດດທີ່ບໍ່ມີລາຍເຊັນຈະຖືກລົບອອກ ຫຼື ອັບເດດ."

#. Translators: the '%s' is replaced with the key ID, usually a few hex digits
#: plugins/packagekit/gs-packagekit-task.c:224
#, c-format
msgid "Do you want to import key %s?"
msgstr "ທ່ານຕ້ອງການນຳເຂົ້າ key %s ບໍ່?"

#. Translators: the '%s' is replaced with the key ID, usually a few hex digits
#: plugins/packagekit/gs-packagekit-task.c:231
#, c-format
msgid "Key %s"
msgstr "Key %s"

#. Translators: the '%s' is replaced with the key user name
#: plugins/packagekit/gs-packagekit-task.c:245
#, c-format
msgid "Key user: %s"
msgstr "ຜູ້ໃຊ້ Key: %s"

#. Translators: the '%s' is replaced with the key fingerprint, a few hex digits
#: plugins/packagekit/gs-packagekit-task.c:247
#, c-format
msgid "Fingerprint: %s"
